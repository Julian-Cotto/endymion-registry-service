# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment files (secrets) — keep template tracked.
# Git only ignores untracked paths; if .env was committed earlier, run: git rm --cached .env
.env
.env.*
!.env.example
.envrc

# Packaging / build
*.egg-info/
.eggs/
dist/
build/
*.egg
pip-wheel-metadata/
share/python-wheels/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
htmlcov/
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# IDE (uncomment if you do not want these in git)
# .idea/
# .vscode/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Logs
*.log

# Local scratch / temp directories
tmp/

# Local archives / large artifacts sometimes dropped in-repo
*.tar.gz
*.tgz
*.AppImage

# Terraform local state (if ever run from repo root)
.terraform/
*.tfstate
*.tfstate.*
tmp