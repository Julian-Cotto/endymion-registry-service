APP_NAME=Portal Registry Service
APP_VERSION=1.0.0
ENVIRONMENT_NAME=local
DEBUG=true

DATABASE_URL=postgresql+psycopg://registry:registry@localhost:5433/portal_registry

AUTH_DISABLED=true

ALLOWED_FRONTEND_HOSTS=localhost,127.0.0.1
ALLOWED_API_HOSTS=localhost,127.0.0.1

SHELL_READ_AUDIENCES=api://portal-registry-runtime
PIPELINE_WRITE_AUDIENCES=api://portal-registry-admin